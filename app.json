{
  "expo": {
    "name": "BSM System",
    "slug": "bsm_mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bsmmobile",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.bsm.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Necessário para escanear QR codes de equipamentos e anexar fotos.",
        "NSPhotoLibraryUsageDescription": "Necessário para selecionar imagens de equipamentos, chamados e avatar."
      }
    },
    "android": {
      "package": "com.bsm.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0F0F10",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F0F10",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Necessário para escanear QR codes de equipamentos.",
          "microphonePermission": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Necessário para selecionar imagens de equipamentos, chamados e avatar."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

